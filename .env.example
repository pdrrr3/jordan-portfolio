# Public Sanity configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-20

# Server-side read token for draft mode (optional but recommended)
SANITY_API_READ_TOKEN=

# Write token for seeding content (only needed for npm run sanity:seed)
SANITY_API_WRITE_TOKEN=
